<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <TextView
        android:id="@+id/confirm_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="STEP 5: CONFIRMATION"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp" />

    <TextView
        android:id="@+id/summary_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Please review your session settings:"
        android:textSize="18sp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/confirm_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/session_summary_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        tools:text="Rounds: 5\nIntensity: 3\nRound Duration: 180s\nRest: 60s\nType: Hand Only"
        android:textSize="16sp"
        android:padding="16dp"

        android:background="?attr/colorSurface"

        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/summary_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <Button
        android:id="@+id/btn_begin_training"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="BEGIN TRAINING"
        android:textSize="20sp"
        android:layout_marginBottom="16dp"
        android:layout_marginStart="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btn_back_confirm" />

    <Button
        android:id="@+id/btn_back_confirm"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="BACK"
        android:textSize="20sp"
        android:layout_marginBottom="16dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_begin_training" />

</androidx.constraintlayout.widget.ConstraintLayout>