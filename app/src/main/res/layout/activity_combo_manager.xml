<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".ComboManagerActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Combo Manager"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/input_combo_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Combo Name (e.g., Jab-Cross)"
        android:inputType="textCapWords" />

    <EditText
        android:id="@+id/input_combo_intensity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Intensity (1-10)"
        android:inputType="number"
        android:layout_marginTop="8dp"/>

    <EditText
        android:id="@+id/input_combo_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Type (e.g., Hand, Foot)"
        android:inputType="textCapWords"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/btn_add_combo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Combo"
        android:layout_gravity="end"
        android:layout_marginTop="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Defined Combos:"
        android:textSize="18sp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/combo_list_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="vertical" />

</LinearLayout>