<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <TextView
        android:id="@+id/duration_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="STEP 2: ROUND &amp; REST TIMES"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp" />

    <TextView
        android:id="@+id/label_round_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Round Duration (seconds):"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/duration_title"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="32dp" />

    <NumberPicker
        android:id="@+id/picker_round_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/label_round_duration"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:theme="@style/ThemeOverlay.AppCompat.Dialog.Alert"/>

    <TextView
        android:id="@+id/label_rest_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rest Duration (seconds):"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/picker_round_duration"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp" />

    <NumberPicker
        android:id="@+id/picker_rest_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/label_rest_duration"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:theme="@style/ThemeOverlay.AppCompat.Dialog.Alert"/>

    <Button
        android:id="@+id/btn_next_duration"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="NEXT"
        android:textSize="20sp"
        android:layout_marginBottom="16dp"
        android:layout_marginStart="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btn_back_duration" />

    <Button
        android:id="@+id/btn_back_duration"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="BACK"
        android:textSize="20sp"
        android:layout_marginBottom="16dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_next_duration" />

</androidx.constraintlayout.widget.ConstraintLayout>