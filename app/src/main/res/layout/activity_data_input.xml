<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".DataInputActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Input Session Data"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/session_summary_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textStyle="italic"
        android:layout_marginBottom="24dp"
        tools:text="Logged: 10 rounds (50 min) at Intensity 2"/>

    <EditText
        android:id="@+id/input_avg_hr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Average Heart Rate (bpm)"
        android:inputType="number" />

    <EditText
        android:id="@+id/input_max_hr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Maximum Heart Rate (bpm)"
        android:inputType="number"
        android:layout_marginTop="8dp"/>

    <EditText
        android:id="@+id/input_calories"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Calories Burned"
        android:inputType="number"
        android:layout_marginTop="8dp"/>

    <EditText
        android:id="@+id/input_training_effect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Training Effect (e.g., 1.0 - 5.0)"
        android:inputType="numberDecimal"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/btn_save_log"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Save Session Log"
        android:layout_gravity="end"
        android:layout_marginTop="24dp"/>

</LinearLayout>